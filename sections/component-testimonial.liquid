{%- if section.settings.show_section -%}
      <section class="component_testimonial_section">
        <div class="padding-section-medium">
          <div class="page-width-full">
            <div class="component_testimonial_container">
              <div class="component_testimonial_nav">
                <div id="testimonial-prev" class="component_testimonial_paginator swiper-button-prev">
                  <div class="component_testimonial_nav_icon w-embed"><svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M8.70694 12.293L4.41394 7.99997H13.9999V5.99997H4.41394L8.70694 1.70697L7.29294 0.292969L0.585938 6.99997L7.29294 13.707L8.70694 12.293Z" fill="#FF8856"></path>
                    </svg></div>
                </div>
                <div id="testimonial-next" class="component_testimonial_paginator swiper-button-next">
                  <div class="component_testimonial_nav_icon w-embed"><svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M5.293 12.293L6.707 13.707L13.414 6.99997L6.707 0.292969L5.293 1.70697L9.586 5.99997H0V7.99997H9.586L5.293 12.293Z" fill="#FF8856"></path>
                    </svg></div>
                </div>
              </div>
              <div id="testimonial-slider" class="component_testimonial_swiper swiper">
                <div class="component_testimonial_wrap swiper-wrapper">
                  {%- if section.blocks.size > 0 -%}
                    {%- for block in section.blocks -%}
                      {%- if block.type == 'testimonial' -%}
                        <div class="component_testimonial_slide swiper-slide" {{ block.shopify_attributes }}>
                          <div class="component_testimonial_card">
                            {%- assign rating = block.settings.rating | default: 5 | at_most: 5 | at_least: 0 -%}
                            {%- if rating > 0 -%}
                              <div class="component_testimonial_stars">
                                {%- for i in (1..rating) -%}
                                  <img src="{{ 'star-icon.svg' | asset_url }}" loading="lazy" width="20" height="19" alt="" class="component_testimonial_star_icon">
                                {%- endfor -%}
                              </div>
                              <div class="spacer-regular"></div>
                            {%- endif -%}
                            <p>{{ block.settings.quote }}</p>
                            <div class="spacer-regular"></div>
                            <p class="text-weight-semibold">{{ block.settings.author }}</p>
                            {%- if block.settings.role != blank -%}<p>{{ block.settings.role }}</p>{%- endif -%}
                          </div>
                        </div>
                      {%- endif -%}
                    {%- endfor -%}
                  {%- else -%}
                    {%- for i in (1..6) -%}
                      <div class="component_testimonial_slide swiper-slide">
                        <div class="component_testimonial_card">
                          <div class="component_testimonial_stars">
                            <img src="{{ 'star-icon.svg' | asset_url }}" loading="lazy" width="20" height="19" alt="" class="component_testimonial_star_icon">
                            <img src="{{ 'star-icon.svg' | asset_url }}" loading="lazy" width="20" height="19" alt="" class="component_testimonial_star_icon">
                            <img src="{{ 'star-icon.svg' | asset_url }}" loading="lazy" width="20" height="19" alt="" class="component_testimonial_star_icon">
                            <img src="{{ 'star-icon.svg' | asset_url }}" loading="lazy" width="20" height="19" alt="" class="component_testimonial_star_icon">
                            <img src="{{ 'star-icon.svg' | asset_url }}" loading="lazy" width="20" height="19" alt="" class="component_testimonial_star_icon">
                          </div>
                          <div class="spacer-regular"></div>
                          <p>“Lorem ipsum dolor sit amet consectetur. Quis tortor diam dictum ultrices eget justo nibh nibh. Massa nisi odio est ultrices arcu tortor nibh.”</p>
                          <div class="spacer-regular"></div>
                          <p class="text-weight-semibold">John Doe</p>
                          <p>Fitness Director, Yacht Co.</p>
                        </div>
                      </div>
                    {%- endfor -%}
                  {%- endif -%}
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="hide w-embed w-script">
          <script>
  runOnDomReady(() => {
     initSlider("#testimonial-slider", {
    			slidesPerView: "auto",
    			spaceBetween: 40,
            navigation: {
    					nextEl: '#testimonial-next',
    					prevEl: '#testimonial-prev',
  					},
  		});
  });
</script>
        </div>
      </section>
{%- endif -%}

{% schema %}
{
  "name": "Testimonial",
  "tag": "section",
  "class": "shopify-section-component-testimonial",
  "settings": [
    { "type": "checkbox", "id": "show_section", "label": "Show this section", "default": true }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "range", "id": "rating", "label": "Rating (stars)", "min": 0, "max": 5, "step": 1, "default": 5 },
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "“Lorem ipsum dolor sit amet consectetur. Quis tortor diam dictum ultrices eget justo nibh nibh. Massa nisi odio est ultrices arcu tortor nibh.”" },
        { "type": "text", "id": "author", "label": "Author", "default": "John Doe" },
        { "type": "text", "id": "role", "label": "Role / company", "default": "Fitness Director, Yacht Co." }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "Testimonial",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
