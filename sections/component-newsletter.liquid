{%- if section.settings.show_section -%}
      <section class="component_newsletter_section">
        <div class="padding-section-regular">
          <div class="page-width-narrower">
            <div class="component_newsletter_wrap">
              <div class="component_newsletter_wrap_item">
                <div class="component_newsletter_headline">
                  <h2>{{ section.settings.heading | default: 'Never Miss an Update' }}</h2>
                  <div class="spacer-small"></div>
                  <p>{{ section.settings.description | default: 'Stay updated on the latest Panthor product news and releases.' }}</p>
                </div>
              </div>
              <div class="component_newsletter_wrap_item">
                <div class="component_newsletter_block w-form">
                  {%- form 'customer', id: 'wf-form-Newsletter-Form', class: 'component_newsletter_form' -%}
                    <input type="hidden" name="contact[tags]" value="{{ section.settings.tag | default: 'newsletter' }}">
                    <label for="Email-Newsletter" class="form_label">{{ section.settings.email_label | default: 'Email' }}</label>
                    <input class="form_input w-input" maxlength="256" name="contact[email]" data-name="Email Newsletter" placeholder="{{ section.settings.email_placeholder | default: 'panthor@email.com' }}" type="email" id="Email-Newsletter" required="">
                    <div class="spacer-medium"></div>
                    <label class="w-checkbox form_checkbox_field"><input type="checkbox" name="contact[accepts_marketing]" id="Newsletter-Terms" data-name="Newsletter Terms" required="" class="w-checkbox-input form_checkbox"><span class="text-size-tiny w-form-label" for="Newsletter-Terms">{{ section.settings.consent_text | default: 'I confirm I wish to receive emails from Panthor. You may opt out of these emails at any time.' }}</span></label>
                    <div class="spacer-medium"></div>
                    <div class="button-group"><input type="submit" data-wait="{{ section.settings.submit_wait | default: 'Please wait...' }}" class="button-tertiary w-button" value="{{ section.settings.submit_label | default: 'Submit' }}"></div>
                    {% render 'wf-form-states', form: form, success_text: section.settings.success_text, error_text: section.settings.error_text %}
                  {%- endform -%}
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="component_newsletter_vector_wrap">
          {%- if section.settings.background_image != blank -%}
            <img src="{{ section.settings.background_image | image_url: width: 679 }}" loading="lazy" width="679" height="539" alt="" class="component_newsletter_vector">
          {%- else -%}
            <img src="{{ 'panthor-watermark-faded-landscape.svg' | asset_url }}" loading="lazy" width="679" height="539" alt="" class="component_newsletter_vector">
          {%- endif -%}
        </div>
      </section>
{%- endif -%}

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "class": "shopify-section-component-newsletter",
  "settings": [
    { "type": "checkbox", "id": "show_section", "label": "Show this section", "default": true },
    { "type": "header", "content": "Headline" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Never Miss an Update" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Stay updated on the latest Panthor product news and releases." },
    { "type": "header", "content": "Form" },
    { "type": "text", "id": "tag", "label": "Customer tag", "default": "newsletter" },
    { "type": "text", "id": "email_label", "label": "Email label", "default": "Email" },
    { "type": "text", "id": "email_placeholder", "label": "Email placeholder", "default": "panthor@email.com" },
    { "type": "text", "id": "consent_text", "label": "Consent text", "default": "I confirm I wish to receive emails from Panthor. You may opt out of these emails at any time." },
    { "type": "text", "id": "submit_label", "label": "Submit button label", "default": "Submit" },
    { "type": "text", "id": "submit_wait", "label": "Submit waiting text", "default": "Please wait..." },
    { "type": "text", "id": "success_text", "label": "Success message", "default": "Thank you! Your submission has been received!" },
    { "type": "text", "id": "error_text", "label": "Error message", "default": "Oops! Something went wrong while submitting the form." },
    { "type": "header", "content": "Background" },
    { "type": "image_picker", "id": "background_image", "label": "Background watermark (leave empty for default)" }
  ],
  "presets": [
    { "name": "Newsletter" }
  ]
}
{% endschema %}
