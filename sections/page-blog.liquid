<main class="main-wrapper">
      <section class="blog_banner_section">
        <div class="page-width">
          <div class="blog_banner_headline">
            <h1>{{ blog.title | default: 'Panthor Resources' }}</h1>
            <div class="spacer-regular"></div>
            <p>Be victorious right from the get-go with our extra resources.</p>
          </div>
        </div>
      </section>
      <section class="blog_overview_section">
        <div class="background-color-primary">
          <div class="padding-section-medium padding-top-0">
            <div class="page-width">
              <div class="blog_overview_filter_wrap">
                <div class="blog_overview_filter_item">
                  <div class="blog_overview_filter_list">
                    <a href="{{ routes.root_url }}blogs/news" aria-current="page" class="blog_overview_filter_button w-inline-block w--current">
                      <div>View All</div>
                    </a>
                    <a href="#" class="blog_overview_filter_button w-inline-block">
                      <div>Category one</div>
                    </a>
                    <a href="#" class="blog_overview_filter_button w-inline-block">
                      <div>Category two</div>
                    </a>
                    <a href="#" class="blog_overview_filter_button w-inline-block">
                      <div>Category three</div>
                    </a>
                    <a href="#" class="blog_overview_filter_button w-inline-block">
                      <div>Category four</div>
                    </a>
                  </div>
                </div>
              </div>
              <div class="spacer-xxlarge"></div>
              <div class="blog_overview_list">
                {%- if blog != blank and blog.articles.size > 0 -%}
                {%- paginate blog.articles by 12 -%}
                {%- for article in blog.articles -%}
                <div class="component_news_card">
                  {%- if article.image -%}
                    <img src="{{ article.image | image_url: width: 1029 }}" loading="lazy" width="445" height="510" alt="{{ article.image.alt | escape }}" sizes="(max-width: 479px) 100vw, 445px" class="component_news_image">
                  {%- else -%}
                    <img src="{{ 'blog-placeholder-image_1.webp' | asset_url }}" loading="lazy" width="445" height="510" alt="" class="component_news_image">
                  {%- endif -%}
                  <div class="component_news_content_wrap">
                    <div class="component_news_content">
                      <h3 class="heading-style-h6">{{ article.title }}</h3>
                      <div class="spacer-xsmall"></div>
                      <p>{{ article.excerpt_or_content | strip_html | truncate: 140 }}</p>
                      <div class="spacer-regular"></div>
                      <div class="button-group">
                        <a href="{{ article.url }}" class="button-secondary is-icon w-inline-block">
                          <div>Read Article</div>
                          <div class="button-icon w-embed"><svg width="8" height="12" viewbox="0 0 8 12" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1.70697 11.8378L7.41397 6.13083L1.70697 0.423828L0.292969 1.83783L4.58597 6.13083L0.292969 10.4238L1.70697 11.8378Z" fill="currentColor"></path></svg></div>
                        </a>
                      </div>
                    </div>
                  </div>
                </div>
                {%- endfor -%}
                {{ paginate | default_pagination }}
                {%- endpaginate -%}
                {%- else -%}
                <div class="component_news_card"><img src="{{ 'blog-placeholder-image_1.webp' | asset_url }}" loading="lazy" width="445" height="510" alt="" srcset="{{ 'blog-placeholder-image_1blog-placeholder-image.webp' | asset_url }} 500w, {{ 'blog-placeholder-image_1blog-placeholder-image.webp' | asset_url }} 800w, {{ 'blog-placeholder-image_1.webp' | asset_url }} 1029w" sizes="(max-width: 479px) 100vw, 445px" class="component_news_image">
