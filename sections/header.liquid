              <path d="M33.6386 13.7151H26.7132L21.5624 29.2709H29.6933L31.0408 23.9562H40.5115L41.8589 29.2709H49.9899L44.839 13.7151H37.9137L38.9312 17.7287H32.6195L33.637 13.7151H33.6386Z" fill="currentColor"></path>
              <path d="M34.3724 10.8246H27.6721L31.0007 0.772217H40.5546L43.8832 10.8246H37.1829L35.7784 5.28446L34.3739 10.8246H34.3724Z" fill="currentColor"></path>
              <path d="M53.0884 13.7151H59.6005V29.2709H53.0884V13.7151Z" fill="currentColor"></path>
              <path d="M62.3232 0.772217H53.0884V10.8246H59.6005V9.69237L60.1972 10.8246H67.6236L62.3232 0.772217Z" fill="currentColor"></path>
              <path d="M79.4011 10.8246V0.772217H72.8889V10.8246H79.4011Z" fill="currentColor"></path>
              <path d="M69.1472 13.7151L72.889 20.8125V13.7151H79.4011V29.2709H69.9212L61.7208 13.7151H69.1472Z" fill="currentColor"></path>
              <path d="M104.657 0.772217H83.5232V7.65181H90.3499V10.8262H97.8302V7.65181H104.657V0.772217Z" fill="currentColor"></path>
              <path d="M90.35 13.7151H97.8303V29.2709H90.35V13.7151Z" fill="currentColor"></path>
              <path d="M108.545 0.772217H116.026V10.8246H108.545V0.772217Z" fill="currentColor"></path>
              <path d="M125.085 0.772217H132.565V10.8246H125.085V0.772217Z" fill="currentColor"></path>
              <path d="M108.545 13.7151H132.565V29.2709H125.085V17.744H116.027V29.2709H108.547V13.7151H108.545Z" fill="currentColor"></path>
              <path d="M145.531 13.7151C145.19 16.3187 145.758 18.9592 147.136 21.1976C148.602 23.4315 151.61 24.0606 153.856 22.6015C154.419 22.2363 154.9 21.7576 155.267 21.1976C156.645 18.9592 157.212 16.3187 156.872 13.7151H164.835C165.234 18.8426 163.011 23.8258 158.919 26.968C154.3 30.2451 148.101 30.2451 143.48 26.968C139.381 23.8335 137.166 18.841 137.599 13.7151H145.528H145.531Z" fill="currentColor"></path>
