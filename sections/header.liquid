              <path d="M177.077 7.13477V10.8246H169.597V0.772217H180.247C185.604 0.772217 189.947 5.09421 189.947 10.4257C189.947 10.5592 189.944 10.6927 189.94 10.8246H182.536C182.758 9.02037 181.468 7.38025 179.656 7.15932C179.524 7.14244 179.39 7.13477 179.256 7.13477H177.079H177.077Z" fill="currentColor"></path>
              <path d="M188.814 13.7151H169.596V29.2709H177.076V18.7659H179.156L185.52 29.2709H193L185.398 16.7238C186.792 16.0502 187.973 15.01 188.813 13.7151H188.814Z" fill="currentColor"></path>
            </svg></div>
          {%- endif -%}
        </a>
      </div>
      <div class="component_header_navigation">
        <div class="component_header_navigation_item is-nav">
          <div class="component_offcanvas">
            <div class="component_nav_list_wrap">
              <div class="component_nav_list_link">
                {%- if section.settings.main_menu != blank and linklists[section.settings.main_menu].links.size > 0 -%}
                  {%- for link in linklists[section.settings.main_menu].links -%}
                    <a href="{{ link.url }}" class="component_nav_link{% if link.active %} w--current{% endif %}">{{ link.title }}</a>
                  {%- endfor -%}
                {%- else -%}
                  <a href="{{ routes.collections_url }}/all" class="component_nav_link">Products</a>
                  <a href="{{ routes.root_url }}pages/affiliates" class="component_nav_link">Affiliates</a>
                  <a href="{{ routes.root_url }}pages/about" class="component_nav_link">About Us</a>
                  <a href="{{ routes.root_url }}blogs/news" class="component_nav_link">Blog</a>
                  <a href="{{ routes.root_url }}pages/contact" class="component_nav_link">Contact</a>
                {%- endif -%}
              </div>
              <div class="component_nav_list_wrap_icon">
                <div class="component_nav_icon_item hide-tablet">
                  <a href="{{ routes.search_url }}" class="w-inline-block">
                    <img src="{{ 'search-icon.svg' | asset_url }}" loading="lazy" width="20" height="20" alt="Search" class="component_nav_list_icon">
                  </a>
                </div>
                <div class="component_nav_icon_item">
                  <a href="{{ routes.account_url }}" class="w-inline-block">
                    <img src="{{ 'profile-icon.svg' | asset_url }}" loading="lazy" width="20" height="20" alt="Account" class="component_nav_list_icon">
                    <div class="show-tablet">
                      <p class="text-color-secondary">{% if customer %}Account{% else %}Log In{% endif %}</p>
                    </div>
                  </a>
                </div>
                <div class="component_nav_icon_item">
                  <a href="{{ routes.cart_url }}" class="w-inline-block">
                    <img src="{{ 'cart-icon.svg' | asset_url }}" loading="lazy" width="20" height="20" alt="Cart" class="component_nav_list_icon">
                    <div class="show-tablet">
                      <p class="text-color-secondary">Cart{% if cart.item_count > 0 %} ({{ cart.item_count }}){% endif %}</p>
                    </div>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="component_header_navigation_item">
          <div class="component_header_widget_wrap">
            <div class="component_header_widget_item">
              <a href="{{ section.settings.cta_url | default: routes.collections_url }}" class="button-primary is-widget w-button">{{ section.settings.cta_label_short | default: 'cUSTOMISE' }} <span class="hide-mobile-portrait">{{ section.settings.cta_label_mid | default: 'YOUR ' }}</span>{{ section.settings.cta_label_end | default: 'MACHINE' }}</a>
              <a href="{{ section.settings.cta_url | default: routes.collections_url }}" class="button-secondary is-desktop w-button">{{ section.settings.cta_label_full | default: 'Customise your machine' }}</a>
            </div>
            <div class="component_header_widget_item is-burger">
              <div data-w-id="ff451305-ab5f-5f04-9caf-f738f2c5f5e8" class="component_header_burger">
                <div class="component_header_burger_line is-top"></div>
                <div class="component_header_burger_line is-middle"></div>
                <div class="component_header_burger_line is-bottom"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "tag": "section",
  "class": "shopify-section-header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo (leave empty for default SVG)" },
    { "type": "link_list", "id": "main_menu", "label": "Main menu", "info": "Falls back to static links if empty." },
    { "type": "header", "content": "Customise CTA Button" },
    { "type": "url", "id": "cta_url", "label": "CTA link" },
    { "type": "text", "id": "cta_label_short", "label": "CTA label (short, primary button)", "default": "cUSTOMISE" },
    { "type": "text", "id": "cta_label_mid", "label": "CTA label (mid)", "default": "YOUR " },
    { "type": "text", "id": "cta_label_end", "label": "CTA label (end)", "default": "MACHINE" },
    { "type": "text", "id": "cta_label_full", "label": "CTA label (secondary button)", "default": "Customise your machine" }
  ],
  "presets": [
    { "name": "Header" }
  ]
}
{% endschema %}
