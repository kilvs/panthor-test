{%- if section.settings.show_section -%}
      <section data-w-id="0f933f72-e676-29c9-3370-2df4c335e6ca" class="component_blurb_section">
        <div class="background-color-primary">
          <div class="padding-section-regular">
            <div class="page-width">
              <div class="component_blurb_headline">
                <div class="component_divider_line"></div>
                <div class="spacer-medium"></div>
                <h2>{{ section.settings.heading | default: 'What can Panthor Complete Strength Do?' }}</h2>
                <div class="spacer-small"></div>
                <div class="component_blurb_description">
                  <p>{{ section.settings.description | default: 'Panthor is the ultimate solution to take your fitness goals from achievable to inevitable. Every single session. Every drop of sweat. Victorious right from the get-go.' }}</p>
                </div>
              </div>
              <div class="spacer-xlarge"></div>
              <div class="component_blurb_list">
                {%- for block in section.blocks -%}
                  {%- if block.type == 'card' -%}
                    <div class="component_blurb_item{% if forloop.index > 1 %} is-{{ forloop.index }}{% endif %}" {{ block.shopify_attributes }}>
                      <div class="component_blurb_card">
                        {%- if block.settings.image != blank -%}
                          <img src="{{ block.settings.image | image_url: width: 886 }}" loading="lazy" alt="{{ block.settings.image.alt | escape }}" sizes="(max-width: 886px) 100vw, 886px" class="component_blurb_image">
                        {%- elsif block.settings.fallback_image != blank -%}
                          <img src="{{ block.settings.fallback_image | asset_url }}" loading="lazy" alt="" sizes="(max-width: 886px) 100vw, 886px" class="component_blurb_image">
                        {%- endif -%}
                        <div class="spacer-regular"></div>
                        <div class="component_divider_line"></div>
                        <div class="spacer-xsmall"></div>
                        <h3 class="heading-style-h5">{{ block.settings.heading }}</h3>
                        <div class="spacer-xsmall"></div>
                        <div class="component_blurb_description w-richtext">
                          {{ block.settings.list }}
                        </div>
                        <div class="component_blurb_bottom">
                          <div class="spacer-xsmall"></div>
                          <p>{{ block.settings.more_text | default: '+ More' }}</p>
                          {%- if block.settings.footnote != blank -%}
                            <div class="spacer-xxsmall"></div>
                            <p class="component_blurb_note">{{ block.settings.footnote }}</p>
                          {%- endif -%}
                        </div>
                      </div>
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            </div>
          </div>
        </div>
      </section>
{%- endif -%}

{% schema %}
{
  "name": "Blurb",
  "tag": "section",
  "class": "shopify-section-component-blurb",
  "settings": [
    { "type": "checkbox", "id": "show_section", "label": "Show this section", "default": true },
    { "type": "header", "content": "Headline" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What can Panthor Complete Strength Do?" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Panthor is the ultimate solution to take your fitness goals from achievable to inevitable. Every single session. Every drop of sweat. Victorious right from the get-go." }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Blurb card",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Body region" },
        { "type": "richtext", "id": "list", "label": "Bullet list", "default": "<ul><li>Exercise one</li><li>Exercise two</li></ul>" },
        { "type": "text", "id": "more_text", "label": "More text", "default": "+ More" },
        { "type": "text", "id": "footnote", "label": "Footnote", "default": "* multiple angles and variations" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "fallback_image", "label": "Fallback image filename", "info": "Used when no image is uploaded." }
      ]
    }
  ],
  "max_blocks": 9,
  "presets": [
    {
      "name": "Blurb",
      "blocks": [
        { "type": "card", "settings": { "heading": "full body", "list": "<ul><li>Squat Press</li></ul><ul><li>Jammer Press</li></ul><ul><li>Lunges*</li></ul><ul><li>Deadlifts*</li></ul>", "fallback_image": "full-body_2.webp" } },
        { "type": "card", "settings": { "heading": "Lower body", "list": "<ul><li>Kickbacks*</li><li>Hamstring Curls</li><li>Leg Extensions</li><li>Leg Presses*</li><li>Glute Bridges</li></ul>", "fallback_image": "lower-body_3.webp" } },
        { "type": "card", "settings": { "heading": "Upper Body", "list": "<ul><li>Shoulder Press</li><li>Chest Press*</li><li>Lat Pull Down</li><li>Bicep & Triceps*</li><li>Rows*</li></ul>", "fallback_image": "upper-body_2.webp" } }
      ]
    }
  ]
}
{% endschema %}
