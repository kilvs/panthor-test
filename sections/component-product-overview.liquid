                        </div>
                        <div class="spacer-small"></div>
                        <div class="component_divider_line"></div>
                        <div class="spacer-small"></div>
                      </div>
                      <div class="component_product_card_bottom">
                        <div class="component_product_card_bottom_item">
                          <h3 class="heading-style-h6">Leather gym bag</h3>
                          <p>$160</p>
                        </div>
                        <div class="component_product_card_add-wrap"><button class="component_product_card_add_button"><img src="{{ 'plus-dark-icon.svg' | asset_url }}" loading="lazy" alt=""></button></div>
