{% schema %}
{
  "name": "Product Overview",
  "tag": "section",
  "class": "shopify-section-component-product-overview",
  "settings": [
    { "type": "checkbox", "id": "show_section", "label": "Show this section", "default": true },
    { "type": "header", "content": "Headline" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Apparel & Accesories" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit." },
