{%- if section.settings.show_section -%}
{%- liquid
  assign featured_collection = section.settings.featured_collection
  assign shop_all_url = section.settings.shop_all_url
  if shop_all_url == blank and featured_collection != blank
    assign shop_all_url = featured_collection.url
  endif
  assign shop_all_url = shop_all_url | default: routes.collections_url | append: '/all'
-%}
      <section class="component_product_overview_section">
        <div class="padding-section-regular">
          <div class="page-width">
            <div class="component_product_overview_headline">
              <div class="text-align-center">
                <h2>{{ section.settings.heading | default: 'Apparel &amp; Accesories' }}</h2>
                <div class="spacer-small"></div>
                <p>{{ section.settings.description | default: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit.' }}</p>
                <div class="spacer-medium"></div>
                {%- if section.settings.show_shop_all -%}
                <div class="button-group is-center">
                  <a href="{{ shop_all_url }}" class="button-secondary w-button">{{ section.settings.shop_all_label | default: 'Shop All' }}</a>
                </div>
                {%- endif -%}
              </div>
            </div>
            <div class="spacer-xxlarge"></div>
          </div>
          <div class="page-width-full">
            <div class="swiper-container">
              <div id="product-slider" class="component_product_overview_swiper swiper">
                <div class="component_product_overview_wrap swiper-wrapper">
                  {%- if featured_collection != blank and featured_collection.products.size > 0 -%}
                    {%- for product in featured_collection.products limit: 12 -%}
                      <div class="component_product_slide swiper-slide">
                        <a href="{{ product.url }}" class="component_product_card" style="text-decoration:none;color:inherit;">
                          <div class="component_product_card_top">
                            <div class="product_card_image_wrap">
                              {%- if product.featured_image -%}
                                <img src="{{ product.featured_image | image_url: width: 700 }}" loading="lazy" width="350" height="400" alt="{{ product.featured_image.alt | escape }}" sizes="(max-width: 479px) 100vw, 350px" class="component_product_card_image">
                              {%- else -%}
                                <img src="{{ 'product-image-placeholder-1_1.webp' | asset_url }}" loading="lazy" width="350" height="400" alt="" class="component_product_card_image">
                              {%- endif -%}
                              <div class="component_product_image_overlay">
                                <span class="component_product_view_button w-inline-block">
                                  <div>View Details</div>
                                  <div class="button-secondary-icon-embed w-embed"><svg width="100%" height="100%" viewbox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M13.4697 8.53033C13.1768 8.23744 13.1768 7.76256 13.4697 7.46967C13.7626 7.17678 14.2374 7.17678 14.5303 7.46967L18.5303 11.4697C18.8232 11.7626 18.8232 12.2374 18.5303 12.5303L14.5303 16.5303C14.2374 16.8232 13.7626 16.8232 13.4697 16.5303C13.1768 16.2374 13.1768 15.7626 13.4697 15.4697L16.1893 12.75H6.5C6.08579 12.75 5.75 12.4142 5.75 12C5.75 11.5858 6.08579 11.25 6.5 11.25H16.1893L13.4697 8.53033Z" fill="currentColor"></path></svg></div>
                                </span>
                              </div>
                            </div>
                            <div class="spacer-small"></div>
                            <div class="component_divider_line"></div>
                            <div class="spacer-small"></div>
                          </div>
                          <div class="component_product_card_bottom">
                            <div class="component_product_card_bottom_item">
                              <h3 class="heading-style-h6">{{ product.title }}</h3>
                              <p>{{ product.price | money }}</p>
                            </div>
                            <div class="component_product_card_add-wrap"><button type="button" class="component_product_card_add_button" data-cart-quick-add="{{ product.selected_or_first_available_variant.id }}" onclick="event.stopPropagation();event.preventDefault();" aria-label="Add {{ product.title | escape }} to cart"{% unless product.available %} disabled{% endunless %}><img src="{{ 'plus-dark-icon.svg' | asset_url }}" loading="lazy" alt=""></button></div>
                          </div>
                        </a>
                      </div>
                    {%- endfor -%}
                  {%- else -%}
                  <div class="component_product_slide swiper-slide">
                    <div class="component_product_card">
                      <div class="component_product_card_top">
                        <div class="product_card_image_wrap"><img src="{{ 'product-image-placeholder-1_1.webp' | asset_url }}" loading="lazy" width="350" height="400" alt="" sizes="(max-width: 479px) 100vw, 350px" srcset="{{ 'product-image-placeholder-1_1product-image-placeholder-1.webp' | asset_url }} 500w, {{ 'product-image-placeholder-1_1.webp' | asset_url }} 700w" class="component_product_card_image">
                          <div class="component_product_image_overlay">
                            <a data-w-id="f88ea6c6-924f-f986-556e-dc9ed864de8c" href="#" class="component_product_view_button w-inline-block">
