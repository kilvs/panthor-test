<main class="main-wrapper">
      <section class="shop_banner_sections">
        <div class="page-width">
          <div class="max-width-large">
            <h1>{{ collection.title | default: 'Shop Panthor' }}</h1>
            <div class="spacer-regular"></div>
            <p>Get the only machine designed to deliver unmatched whole-body strength training in one complete system. It’s time to make your move.</p>
          </div>
        </div>
        <div class="shop_banner_background"><img src="{{ 'panthor-watermark-faded-landscape.svg' | asset_url }}" loading="lazy" width="602" height="477" alt="" class="shop_banner_background_image"><img src="{{ 'panthor-watermark-faded-landscape.svg' | asset_url }}" loading="lazy" width="602" height="477" alt="" class="shop_banner_background_image"></div>
      </section>
      <section class="shop_system_section">
        <div class="background-color-primary">
          <div class="padding-section-small">
            <div class="page-width">
              <div class="shop_system_wrap">
                <div class="shop_system_wrap_item"><img class="shop_system_image" src="{{ 'panthor-system_1.webp' | asset_url }}" width="556" height="610" alt="" sizes="(max-width: 767px) 100vw, 556px" id="shop_sytstem_image" loading="lazy" srcset="{{ 'panthor-system_1panthor-system.webp' | asset_url }} 500w, {{ 'panthor-system_1panthor-system.webp' | asset_url }} 800w, {{ 'panthor-system_1panthor-system.webp' | asset_url }} 1080w, {{ 'panthor-system_1.webp' | asset_url }} 1132w"></div>
                <div class="shop_system_wrap_item">
                  <div class="shop_system_content">
                    <h2>Panthor Complete  <br>Strength System</h2>
                    <div class="spacer-regular"></div>
                    <div class="shop_system_description">
                      <p>Transform your fitness routine and enjoy unparalleled workouts with the machine that honours training the way you need.</p>
                    </div>
                    <div class="spacer-regular"></div>
                    <div class="shop_system_subheading">
                      <h3 class="text-size-small text-style-allcaps">Customise your Panthor:</h3>
                    </div>
                    <div class="spacer-regular"></div>
                    <div class="shop_system_list">
                      <div class="shop_system_item">
                        <div class="shop_system_card">
                          <div class="shop_system_heading">
                            <h4 class="text-size-small text-style-allcaps text-color-alternate">Bolt Down</h4>
                          </div>
                          <div class="spacer-small"></div>
                          <p>Our most compact setup, ideal for maximum floor space eficiency.</p>
                        </div>
                      </div>
                      <div class="shop_system_item">
                        <div class="shop_system_card">
                          <div class="shop_system_heading">
                            <h4 class="text-size-small text-style-allcaps text-color-alternate">Bench</h4>
                          </div>
                          <div class="spacer-small"></div>
                          <p>Custom built to pair with the Panthor system, our bench elevates your workout with a wide range of exercises.</p>
                        </div>
                      </div>
                      <div class="shop_system_item">
                        <div class="shop_system_card">
                          <div class="shop_system_heading">
                            <h4 class="text-size-small text-style-allcaps text-color-alternate">Freestanding</h4>
                          </div>
                          <div class="spacer-small"></div>
                          <p>Our retrofittable freestanding platform works seamlessly with the bench, but is also fully functional alone,</p>
                        </div>
                      </div>
                    </div>
                    <div class="spacer-medium"></div>
                    <div class="button-group">
                      <a href="#" class="button-primary w-button">Customise Your Machine</a>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
      <section class="shop_overview_section">
        <div class="background-color-primary">
          <div class="padding-section-medium">
            <div class="page-width">
              <div class="shop_list">
