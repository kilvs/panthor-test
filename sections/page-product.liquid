<main class="main-wrapper">
      <section class="product_detail_section">
        <div class="page-width">
          <div class="product_detail_breadcrumbs">
            <a href="{{ routes.collections_url }}/all" class="product_detail_breadcrumb_link">Shop All</a>
            <div class="product_detail_breadcrumb_icon w-embed"><svg width="6" height="8" viewbox="0 0 6 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1.47099 7.79976L5.27565 3.9951L1.47099 0.19043L0.52832 1.1331L3.39032 3.9951L0.52832 6.8571L1.47099 7.79976Z" fill="white"></path>
              </svg></div>
            {%- assign _cat_collection = product.collections.first -%}
            <a href="{{ _cat_collection.url | default: routes.collections_url | append: '/all' }}" class="product_detail_breadcrumb_link">{{ _cat_collection.title | default: 'Category' }}</a>
            <div class="product_detail_breadcrumb_icon w-embed"><svg width="6" height="8" viewbox="0 0 6 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1.47099 7.79976L5.27565 3.9951L1.47099 0.19043L0.52832 1.1331L3.39032 3.9951L0.52832 6.8571L1.47099 7.79976Z" fill="white"></path>
              </svg></div>
            <a href="{{ product.url | default: '#' }}" aria-current="page" class="product_detail_breadcrumb_link w--current">{{ product.title | default: 'Product name' }}</a>
          </div>
          <div class="spacer-regular"></div>
          <div class="product_detail_grid">
            <div class="product_detail_grid_item">
              <div class="product_detail_featured_image_wrap">
                {%- if product != blank and product.featured_image -%}
                  <img src="{{ product.featured_image | image_url: width: 1360 }}" loading="lazy" width="680" height="600" alt="{{ product.featured_image.alt | escape }}" sizes="(max-width: 767px) 100vw, 680px" class="product_detail_featured_image">
                {%- else -%}
                  <img src="{{ 'featured-image_1.webp' | asset_url }}" loading="lazy" width="680" height="600" alt="" srcset="{{ 'featured-image_1featured-image.webp' | asset_url }} 500w, {{ 'featured-image_1featured-image.webp' | asset_url }} 800w, {{ 'featured-image_1featured-image.webp' | asset_url }} 1080w, {{ 'featured-image_1.webp' | asset_url }} 1360w" sizes="(max-width: 767px) 100vw, 680px" class="product_detail_featured_image">
                {%- endif -%}
              </div>
              <div class="product_gallery_wrap">
                <div class="product_gallery">
                  <div class="product_gallery_nav_item">
                    <div id="gallery-prev" class="product_gallery_nav swiper-button-prev">
                      <div class="product_gallery_nav_icon w-embed"><svg width="100%" height="100%" viewbox="0 0 8 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M6.29303 11.9496L0.586032 6.24264L6.29303 0.535645L7.70703 1.94964L3.41403 6.24264L7.70703 10.5356L6.29303 11.9496Z" fill="black"></path>
                        </svg></div>
                    </div>
                  </div>
                  <div class="product_gallery_swiper_box">
                    <div class="gallery-container">
                      <div id="product-gallery-slider" class="product_image_swiper swiper">
                        <div class="product_image_swiper_wrap swiper-wrapper">
                          {%- if product != blank and product.media.size > 0 -%}
                            {%- for media in product.media -%}
                              <div class="product_image_slide swiper-slide"><img src="{{ media | image_url: width: 1360 }}" loading="lazy" width="113" height="96" alt="{{ media.alt | escape }}" class="product_gallery_image"></div>
                            {%- endfor -%}
                          {%- else -%}
                            <div class="product_image_slide swiper-slide"><img src="{{ 'featured-image_1.webp' | asset_url }}" loading="lazy" width="113" height="96" alt="" sizes="113px" srcset="{{ 'featured-image_1featured-image.webp' | asset_url }} 500w, {{ 'featured-image_1featured-image.webp' | asset_url }} 800w, {{ 'featured-image_1featured-image.webp' | asset_url }} 1080w, {{ 'featured-image_1.webp' | asset_url }} 1360w" class="product_gallery_image"></div>
                            <div class="product_image_slide swiper-slide"><img src="{{ 'product-1.webp' | asset_url }}" loading="lazy" width="113" height="96" alt="" class="product_gallery_image"></div>
                            <div class="product_image_slide swiper-slide"><img src="{{ 'product-2.webp' | asset_url }}" loading="lazy" width="113" height="96" alt="" class="product_gallery_image"></div>
                            <div class="product_image_slide swiper-slide"><img src="{{ 'product-3.webp' | asset_url }}" loading="lazy" width="113" height="96" alt="" class="product_gallery_image"></div>
                            <div class="product_image_slide swiper-slide"><img src="{{ 'product-4.webp' | asset_url }}" loading="lazy" width="113" height="96" alt="" class="product_gallery_image"></div>
                            <div class="product_image_slide swiper-slide"><img src="{{ 'product-5.webp' | asset_url }}" loading="lazy" width="113" height="96" alt="" class="product_gallery_image"></div>
                            <div class="product_image_slide swiper-slide"><img src="{{ 'product-1.webp' | asset_url }}" loading="lazy" width="113" height="96" alt="" class="product_gallery_image"></div>
                            <div class="product_image_slide swiper-slide"><img src="{{ 'product-2.webp' | asset_url }}" loading="lazy" width="113" height="96" alt="" class="product_gallery_image"></div>
                          {%- endif -%}
                        </div>
                      </div>
                    </div>
                  </div>
                  <div class="product_gallery_nav_item">
                    <div id="gallery-next" class="product_gallery_nav swiper-button-next">
                      <div class="product_gallery_nav_icon w-embed"><svg width="100%" height="100%" viewbox="0 0 8 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M1.70697 11.9496L7.41397 6.24264L1.70697 0.535645L0.292969 1.94964L4.58597 6.24264L0.292969 10.5356L1.70697 11.9496Z" fill="black"></path>
                        </svg></div>
                    </div>
                  </div>
                </div>
                <div class="hide w-embed w-script">
                  <script>
  runOnDomReady(() => {
     initSlider("#product-gallery-slider", {
    			slidesPerView: 5,
    			spaceBetween: 16,
          navigation:{
          	 nextEl: '#gallery-next',
   					 prevEl: '#gallery-prev',
          },
          breakpoints: {
           0: {
           		slidesPerView: 1
           },
       		 992: {
           		slidesPerView: 3,
              initialSlide: 1
           },
           1280: {
           		slidesPerView: 5,
              initialSlide: 1
           }
          }
  		});
      });
</script>
                </div>
              </div>
