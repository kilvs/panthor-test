const initSliderTransformRemover = (swiper) => {
  const { el, slides } = swiper;
  if (!el.classList.contains("init-slider-transform-remover")) {
    el.classList.add("init-slider-transform-remover");
    slides.forEach((slide) => {
      const transformedElements = slide.querySelectorAll(
        "[data-slider='transform-element']"
      );
      const setters = slide.querySelectorAll(
        "[data-slider='transform-setter']"
      );
      if (setters.length > 0) {
        setters.forEach((setter) => {
          setter.addEventListener("click", () => {
            slide.classList.add("transform-none");
            swiper.wrapperEl.classList.add("transform-none");
            el.closest(".swiper-container").style.zIndex = 9999;
            if (transformedElements.length > 0) {
              transformedElements.forEach((element) => {
                element.classList.add("transform-none");
              });
            }
          });
        });
      }
      const resetters = slide.querySelectorAll(
        "[data-slider='transform-resetter']"
      );
      if (resetters.length > 0) {
        resetters.forEach((resetter) => {
          resetter.addEventListener("click", () => {
            slide.classList.remove("transform-none");
            swiper.wrapperEl.classList.remove("transform-none");
            el.closest(".swiper-container").removeAttribute("style");
            if (transformedElements.length > 0) {
              transformedElements.forEach((element) => {
                element.classList.remove("transform-none");
              });
            }
          });
        });
      }
    });
  }
};
  /*Typewriter*/
function typeTextOnView(id, speed = 35) {
  const element = document.getElementById(id);
  if (!element) return;
  let hasAnimated = false;
  // Utility: wrap text node characters in span
  function wrapCharactersInSpans(node) {
    const fragment = document.createDocumentFragment();
    node.textContent.split('').forEach(char => {
      const span = document.createElement('span');
      span.textContent = char;
      span.style.opacity = '0.6';
      span.style.transition = 'opacity 0.3s ease';
      fragment.appendChild(span);
    });
    return fragment;
  }
  // Recursive function to walk the DOM and wrap only text nodes
  function processNode(node) {
    if (node.nodeType === Node.TEXT_NODE) {
      const spanWrapped = wrapCharactersInSpans(node);
      node.replaceWith(spanWrapped);
    } else if (node.nodeType === Node.ELEMENT_NODE) {
      node.childNodes.forEach(child => processNode(child));
    }
  }
  // Preserve layout height
  const clone = element.cloneNode(true);
  clone.style.position = 'absolute';
  clone.style.visibility = 'hidden';
  clone.style.pointerEvents = 'none';
  clone.style.height = 'auto';
  clone.style.opacity = 1;
  element.parentNode.insertBefore(clone, element.nextSibling);
  const fixedHeight = clone.offsetHeight + 'px';
  clone.remove();
  element.style.height = fixedHeight;
  element.style.overflow = 'hidden';
  // Typewriter animation (opacity fade)
  function typeWriter() {
    const spans = element.querySelectorAll('span');
    let i = 0;
    function fadeChar() {
      if (i < spans.length) {
        spans[i].style.opacity = '1';
        i++;
        setTimeout(fadeChar, speed);
      }
    }
    fadeChar();
  }
