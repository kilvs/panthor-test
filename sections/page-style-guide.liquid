  const observer = new IntersectionObserver(
    (entries, observer) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && !hasAnimated) {
          hasAnimated = true;
          typeWriter();
          observer.unobserve(element);
        }
      });
    },
    { threshold: 0.5 }
  );
  observer.observe(element);
  // Run character wrapping after DOM is loaded
  processNode(element);
}
