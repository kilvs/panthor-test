            <div class="spacer-medium"></div>
            <div class="button-group">
              <a href="#" class="button-primary w-button">Search</a>
              <a href="{{ routes.root_url }}" class="button-secondary w-button">Home</a>
            </div>
          </div>
        </div>
        <div class="_404_hero_vector_wrap"><img src="{{ 'panthor-gradient-icon.webp' | asset_url }}" loading="lazy" sizes="(max-width: 1728px) 100vw, 1728px" srcset="{{ 'panthor-gradient-icon-p-500.png' | asset_url }} 500w, {{ 'panthor-gradient-icon-p-800.png' | asset_url }} 800w, {{ 'panthor-gradient-icon-p-1080.png' | asset_url }} 1080w, {{ 'panthor-gradient-icon-p-1600.png' | asset_url }} 1600w, {{ 'panthor-gradient-icon.webp' | asset_url }} 1728w" alt="" class="_404_hero_vector"></div>
