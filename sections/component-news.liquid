{%- if section.settings.show_section -%}
{%- liquid
  assign blog_obj = section.settings.featured_blog
  assign view_all_url = section.settings.view_all_url
  if view_all_url == blank and blog_obj != blank
    assign view_all_url = blog_obj.url
  endif
  assign view_all_url = view_all_url | default: routes.root_url | append: 'blogs/news'

  assign chevron_svg = '<div class="button-icon w-embed"><svg width="8" height="12" viewbox="0 0 8 12" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1.70697 11.8378L7.41397 6.13083L1.70697 0.423828L0.292969 1.83783L4.58597 6.13083L0.292969 10.4238L1.70697 11.8378Z" fill="currentColor"></path></svg></div>'
  assign read_label = section.settings.card_cta_label | default: 'Read Article'
-%}
      <section class="component_news_section">
        <div class="component_news_overflow">
          <div class="component_news_background">
            {%- if section.settings.background_image != blank -%}
              <img src="{{ section.settings.background_image | image_url: width: 1200 }}" loading="lazy" alt="" class="component_news_background_image">
            {%- else -%}
              <img src="{{ 'panthor-watermark-faded-landscape.svg' | asset_url }}" loading="lazy" alt="" class="component_news_background_image">
            {%- endif -%}
          </div>
          <div class="padding-section-regular">
            <div class="page-width">
              <div class="max-width-large align-center">
                <div class="text-align-center">
                  <h2>{{ section.settings.heading | default: 'Panthor Insights and News' }}</h2>
                  <div class="spacer-small"></div>
                  <p>{{ section.settings.description | default: 'Stay informed about our latest offerings and insights.' }}</p>
                  {%- if section.settings.show_view_all -%}
                    <div class="spacer-medium"></div>
                    <a href="{{ view_all_url }}" class="button-secondary w-button">{{ section.settings.view_all_label | default: 'View All Blogs' }}</a>
                  {%- endif -%}
                </div>
              </div>
            </div>
            <div class="spacer-xlarge"></div>
            <div class="page-width-full">
              <div class="swiper-container">
                <div id="news-slider" class="component_news_slider swiper">
                  <div class="component_news_wrap swiper-wrapper">
                    {%- if blog_obj != blank and blog_obj.articles.size > 0 -%}
                      {%- for article in blog_obj.articles limit: 12 -%}
                        <div class="component_news_slide swiper-slide">
                          <div class="component_news_card">
                            {%- if article.image -%}
                              <img src="{{ article.image | image_url: width: 1029 }}" loading="lazy" width="445" height="510" alt="{{ article.image.alt | escape }}" sizes="(max-width: 479px) 100vw, 445px" class="component_news_image">
                            {%- else -%}
                              <img src="{{ 'blog-placeholder-image_1.webp' | asset_url }}" loading="lazy" width="445" height="510" alt="" class="component_news_image">
                            {%- endif -%}
                            <div class="component_news_content_wrap">
                              <div class="component_news_content">
                                <h3 class="heading-style-h6">{{ article.title }}</h3>
                                <div class="spacer-xsmall"></div>
                                <p>{{ article.excerpt_or_content | strip_html | truncate: 140 }}</p>
                                <div class="spacer-regular"></div>
                                <div class="button-group">
                                  <a href="{{ article.url }}" class="button-secondary is-icon w-inline-block">
                                    <div>{{ read_label }}</div>
                                    {{ chevron_svg }}
                                  </a>
                                </div>
                              </div>
                            </div>
                          </div>
                        </div>
                      {%- endfor -%}
                    {%- else -%}
                      {%- for block in section.blocks -%}
                        {%- if block.type == 'card' -%}
                          <div class="component_news_slide swiper-slide" {{ block.shopify_attributes }}>
                            <div class="component_news_card">
                              {%- if block.settings.image != blank -%}
                                <img src="{{ block.settings.image | image_url: width: 1029 }}" loading="lazy" width="445" height="510" alt="{{ block.settings.image.alt | escape }}" sizes="(max-width: 479px) 100vw, 445px" class="component_news_image">
                              {%- else -%}
                                <img src="{{ 'blog-placeholder-image_1.webp' | asset_url }}" loading="lazy" width="445" height="510" alt="" class="component_news_image">
                              {%- endif -%}
                              <div class="component_news_content_wrap">
                                <div class="component_news_content">
                                  <h3 class="heading-style-h6">{{ block.settings.heading }}</h3>
                                  <div class="spacer-xsmall"></div>
                                  <p>{{ block.settings.body }}</p>
                                  <div class="spacer-regular"></div>
                                  <div class="button-group">
                                    {%- assign card_url = block.settings.url | default: view_all_url -%}
                                    <a href="{{ card_url }}" class="button-secondary is-icon w-inline-block">
                                      <div>{{ block.settings.cta_label | default: read_label }}</div>
                                      {{ chevron_svg }}
                                    </a>
                                  </div>
                                </div>
                              </div>
                            </div>
                          </div>
                        {%- endif -%}
                      {%- endfor -%}
                    {%- endif -%}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="hide w-embed w-script">
          <script>
  runOnDomReady(() => {
     initSlider("#news-slider", {
    			slidesPerView: "auto",
    			spaceBetween: 12
  		});
  });
</script>
        </div>
      </section>
{%- endif -%}

{% schema %}
{
  "name": "News",
  "tag": "section",
  "class": "shopify-section-component-news",
  "settings": [
    { "type": "checkbox", "id": "show_section", "label": "Show this section", "default": true },
    { "type": "header", "content": "Headline" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Panthor Insights and News" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Stay informed about our latest offerings and insights." },
    { "type": "header", "content": "View all button" },
    { "type": "checkbox", "id": "show_view_all", "label": "Show button", "default": true },
    { "type": "text", "id": "view_all_label", "label": "Button label", "default": "View All Blogs" },
    { "type": "url", "id": "view_all_url", "label": "Custom URL (fallback)" },
    { "type": "header", "content": "Source" },
    { "type": "blog", "id": "featured_blog", "label": "Blog to feature", "info": "When set, the slider renders the first 12 articles. When empty, the static placeholder cards below are shown." },
    { "type": "text", "id": "card_cta_label", "label": "Per-card CTA label", "default": "Read Article" },
    { "type": "header", "content": "Background" },
    { "type": "image_picker", "id": "background_image", "label": "Background watermark (leave empty for default)" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Placeholder news card",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Innovations in Marine Fitness Equipment" },
        { "type": "textarea", "id": "body", "label": "Body", "default": "Discover how our equipment enhances fitness on luxury yachts." },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Read Article" },
        { "type": "url", "id": "url", "label": "CTA URL" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "News",
      "blocks": [
        { "type": "card" }, { "type": "card" }, { "type": "card" },
        { "type": "card" }, { "type": "card" }, { "type": "card" }
      ]
    }
  ]
}
{% endschema %}
