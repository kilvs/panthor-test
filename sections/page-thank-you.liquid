<main class="main-wrapper">
      <section class="thank_hero_section">
        <div class="page-width">
          <div class="thank_hero_grid">
            <div class="thank_hero_item">
              <div class="thank_hero_content">
                <div class="thank_hero_top">
                  <div class="component_divider_line"></div>
                  <h1>Thank You!</h1>
                </div>
                <div class="thank_hero_bottom">
                  <p>You’ve made the right move to take your fitness goals <br>from achievable to inevitable.</p>
                  <div class="spacer-medium"></div>
                  <div class="button-group">
                    <a href="{{ routes.root_url }}" class="button-primary w-button">Home</a>
                    <a href="{{ routes.root_url }}pages/about" class="button-alternate w-button">About Us</a>
                  </div>
                </div>
              </div>
            </div>
            <div class="thank_hero_item">
              <div class="thank_hero_image_wrap"><img src="{{ 'thank-you-placeholder_1.webp' | asset_url }}" loading="lazy" sizes="(max-width: 808px) 100vw, 808px" srcset="{{ 'thank-you-placeholder_1thank-you-placeholder.webp' | asset_url }} 500w, {{ 'thank-you-placeholder_1thank-you-placeholder.webp' | asset_url }} 800w, {{ 'thank-you-placeholder_1.webp' | asset_url }} 808w" alt="" class="thank_hero_image"></div>
            </div>
          </div>
        </div>
      </section>
